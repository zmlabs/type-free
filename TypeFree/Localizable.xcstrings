    "Choose a preset key or record any key as your trigger.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie eine voreingestellte Taste oder nehmen Sie eine beliebige Taste als Auslöser auf."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una tecla preestablecida o graba cualquier tecla como disparador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une touche prédéfinie ou enregistrez n’importe quelle touche comme déclencheur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un tasto preimpostato o registra qualsiasi tasto come attivatore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プリセットキーを選択するか、任意のキーをトリガーとして記録してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사전 설정된 키를 선택하거나 임의의 키를 트리거로 기록하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择预设按键或录制任意按键作为触发键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇預設按鍵或錄製任意按鍵作為觸發鍵。"
          }
        }
      }
    },
