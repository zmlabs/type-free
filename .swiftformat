--exclude .git,.build,DerivedData,.agents,.codex,.specify,TypeFree.xcodeproj
--swiftversion 6
--indent 4
--linebreaks lf
--maxwidth 120
--trimwhitespace always
--header ignore
--semicolons inline-only
--commas always
--self remove
--stripunusedargs always
--allman false
--indentcase false
--ifdef indent
--guardelse auto
--wraparguments preserve
--wrapparameters preserve
--wrapcollections preserve
--wrapconditions preserve
--wrapreturntype preserve
--wrapeffects preserve
--closingparen balanced
--call-site-paren balanced
--importgrouping testable-last,alpha
--extensionacl on-extension
--redundantasync tests-only
--redundantthrows tests-only
--modifier-order override,nonisolated,nonisolated(unsafe),private,fileprivate,internal,package,public,open,private(set),fileprivate(set),internal(set),package(set),public(set),open(set),final,dynamic,optional,required,convenience,indirect,isolated,lazy,weak,unowned,unowned(safe),unowned(unsafe),static,class,borrowing,consuming,mutating,nonmutating,prefix,infix,postfix,async
--suitenameformat preserve
--testcasenameformat preserve
--disable sortDeclarations
